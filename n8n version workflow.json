  "appendices": {
    "glossary": [
      { "term": "Diff", "definition": "Visual representation of changes between two document versions." },
      { "term": "Sign-off", "definition": "Formal approval action that transitions status to Published." },
      { "term": "Draft / In Progress", "definition": "Initial editable state after upload or new version creation." }
